---
import game from '../../../shared/game.json';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${game.name} — Press Kit`,
  description = `${game.tagline} Press kit for content creators and press.`,
  ogImage = '/assets/images/hero1-1200x670.webp',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={`https://serenitysketch.com${ogImage}`}>
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://serenitysketch.com/presskit">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" type="image/png" href="/assets/images/path-sigils/sigil-path-of-initiation-black.png">
  <title>{title}</title>
  <link rel="preload" href="/assets/fonts/baloo2-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/styles/fonts.css">
  <link rel="stylesheet" href="/styles/main.css">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": game.name,
    "description": game.longDescription,
    "url": game.website,
    "gamePlatform": game.platform,
    "operatingSystem": "iPadOS",
    "applicationCategory": "Game",
    "author": {
      "@type": "Organization",
      "name": game.developer,
      "url": game.studioUrl
    }
  })} />
</head>
<body>
  <slot />
</body>
</html>
