---
import game from '../../../shared/game.json';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${game.name} — ${game.tagline}`,
  description = game.shortDescription,
  ogImage = '/assets/images/hero1-1200x670.webp',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={`https://serenitysketch.com${ogImage}`}>
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://serenitysketch.com">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" type="image/png" href="/assets/images/path-sigils/sigil-path-of-initiation-black.png">
  <title>{title}</title>

  <link rel="preconnect" href="https://i.ytimg.com" crossorigin>
  <link rel="preconnect" href="https://assets.mailerlite.com" crossorigin>
  <link rel="preload" href="/assets/fonts/baloo2-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/styles/fonts.css">
  <link rel="stylesheet" href="/styles/main.css">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": game.name,
    "description": game.longDescription,
    "url": game.website,
    "gamePlatform": game.platform,
    "operatingSystem": "iPadOS",
    "applicationCategory": "Game",
    "author": {
      "@type": "Organization",
      "name": game.developer,
      "url": game.studioUrl
    }
  })} />

  <style is:global>
    /* Aliases so index.astro's --color-* refs resolve to main.css tokens */
    :root {
      --color-bg:         var(--paper);
      --color-text:       var(--ink);
      --color-text-muted: var(--ink-soft);
      --color-accent:     var(--copper);
      --color-accent-dark:var(--copper-deep);
      --color-border:     var(--rule);
    }
    html { scroll-behavior: smooth; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
